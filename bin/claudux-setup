#!/usr/bin/env bash
# claudux-setup — Install/uninstall claudux in tmux.conf
set -euo pipefail

CLAUDUX_DIR=""
TMUX_CONF="${HOME}/.tmux.conf"

# Resolve where claudux is installed
resolve_claudux_dir() {
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"

    # If installed via Homebrew: bin/ is in $(brew --prefix)/bin, scripts in $(brew --prefix)/share/claudux
    if [[ -d "${self_dir}/../share/claudux/scripts" ]]; then
        CLAUDUX_DIR="${self_dir}/../share/claudux"
    # If installed manually: bin/ is next to scripts/
    elif [[ -d "${self_dir}/../scripts" ]]; then
        CLAUDUX_DIR="$(cd "${self_dir}/.." && pwd)"
    else
        echo "Error: Cannot find claudux scripts directory." >&2
        exit 1
    fi
}

cmd_install() {
    resolve_claudux_dir

    # Resolve to absolute path
    local scripts_dir
    scripts_dir="$(cd "$CLAUDUX_DIR/scripts" && pwd)"

    # Create tmux.conf if it doesn't exist
    touch "$TMUX_CONF"

    # Check if already installed
    if grep -q "claudux" "$TMUX_CONF" 2>/dev/null; then
        echo "claudux is already in $TMUX_CONF"
        echo "Run 'claudux-setup uninstall' first to reinstall."
        exit 0
    fi

    # Append claudux config
    cat >> "$TMUX_CONF" << EOF

# Claudux — Claude API usage monitor
set -g status-right-length 200
set -g status-right '#(${scripts_dir}/claudux.sh weekly) #(${scripts_dir}/claudux.sh sonnet) #(${scripts_dir}/claudux.sh opus) #(${scripts_dir}/claudux.sh reset) #(${scripts_dir}/claudux.sh status) | %H:%M'
EOF

    echo "✓ claudux added to $TMUX_CONF"
    echo ""
    echo "Reload tmux config:"
    echo "  tmux source-file ~/.tmux.conf"
    echo ""
    echo "Or restart tmux."
}

cmd_uninstall() {
    if [[ ! -f "$TMUX_CONF" ]]; then
        echo "No $TMUX_CONF found."
        exit 0
    fi

    # Remove claudux lines (the comment + two set lines)
    local tmp
    tmp=$(mktemp)
    grep -v "claudux" "$TMUX_CONF" | grep -v "# Claudux" > "$tmp" || true
    mv "$tmp" "$TMUX_CONF"

    echo "✓ claudux removed from $TMUX_CONF"
    echo "Reload tmux config to apply."
}

cmd_status() {
    resolve_claudux_dir

    echo "claudux status"
    echo "─────────────────────────"
    echo "Scripts:  $CLAUDUX_DIR/scripts/"
    echo "Config:   $TMUX_CONF"

    if grep -q "claudux" "$TMUX_CONF" 2>/dev/null; then
        echo "Installed: yes"
    else
        echo "Installed: no (run 'claudux-setup install')"
    fi

    # Check dependencies
    local deps_ok=true
    for dep in jq curl tmux bash; do
        if command -v "$dep" >/dev/null 2>&1; then
            echo "  $dep: $(command -v "$dep")"
        else
            echo "  $dep: MISSING"
            deps_ok=false
        fi
    done

    # Check cache
    local cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/claudux"
    if [[ -f "$cache_dir/cache.json" ]]; then
        echo "Cache:    $cache_dir/cache.json ($(wc -c < "$cache_dir/cache.json") bytes)"
    else
        echo "Cache:    not yet created"
    fi
}

cmd_help() {
    cat << 'EOF'
claudux-setup — Configure claudux tmux plugin

Usage:
  claudux-setup install     Add claudux to ~/.tmux.conf
  claudux-setup uninstall   Remove claudux from ~/.tmux.conf
  claudux-setup status      Show installation status and dependencies
  claudux-setup help        Show this help

After install, reload tmux:
  tmux source-file ~/.tmux.conf
EOF
}

case "${1:-help}" in
    install)   cmd_install ;;
    uninstall) cmd_uninstall ;;
    status)    cmd_status ;;
    help|--help|-h) cmd_help ;;
    *)
        echo "Unknown command: $1"
        cmd_help
        exit 1
        ;;
esac
